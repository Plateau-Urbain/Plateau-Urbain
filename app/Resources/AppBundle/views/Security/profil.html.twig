                                        </li>
                                        {% endif %}
                                        </ul>
                                        {% if form.kbis is not defined %}
                                            <div class="kbis-file file-infos clearfix">
                                                <div class="clearfix actions overflow">
                                                    {% set file =  app.user.getDocumentsType('kbis')[0] %}
                                                    <div style="display:inline-block; width:80%">{{ file.originalname }}</div>
                                                    <div style="display:inline-block" class="pull-right">
                                                        <a target="_blank" href="{{ asset(vich_uploader_asset(file, 'file')) }}"><i class="fa fa-eye"></i></a>
                                                        <a href="{{ path('profile_removedocument', { 'id': file.id, 'anchor': 'four' }) }}"><i class="fa fa-trash"></i></a>
                                                    </div>
                                                </div>
                                            </div>
                                        {% elseif form.kbis is defined %}
                                            <div class="kbis-file file-infos clearfix{% if not form.kbis.vars.valid %} has-error{% endif %}">
                                                <div class="actions overflow">
                                                    <label class="btn btn-accepted">
