                                </div>
                            </div>
                            <div class="row">
                                <div class="col-sm-12 form-group">
                                    {{ form_row(form.userInfo.description, {'attr': {'placeholder': 'Décrivez-vous en quelques mots (emojis non autorisés)'}}) }}
                                </div>
                            </div>
