                            // Réactiver le lien en cas d'erreur
                            $link.prop('disabled', false).html('<i class="fa fa-trash"></i>');
                            
                            // Afficher un message d'erreur
                            alert('Erreur lors de la suppression du document. Veuillez réessayer.');
                        }
                    });
                    
                    return false;
                }
            });
            
