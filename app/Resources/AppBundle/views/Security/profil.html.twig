                                        'attr': {
                                            'aria-required': 'true',
                                            'aria-invalid': form.userInfo.civility.vars.errors|length ? 'true' : 'false',
                                            'aria-describedby': 'civility-error'
                                        }
                                    }) }}
                                    {{ form_errors(form.userInfo.civility, {
                                        'attr': {
                                            'id': 'civility-error',
                                            'role': 'alert',
                                            'aria-live': 'polite'
                                        }
                                    }) }}
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-sm-6 form-group{% if form.userInfo.firstname.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.userInfo.firstname, null, {'label_attr': {'class': 'required'}}) }}
                                    {{ form_widget(form.userInfo.firstname, {
                                        'attr': {
                                            'required': 'required',
                                            'aria-required': 'true',
                                            'aria-invalid': form.userInfo.firstname.vars.errors|length ? 'true' : 'false',
                                            'aria-describedby': 'firstname-error',
                                            'data-error-message': 'Veuillez renseigner votre prénom'
                                        }
                                    }) }}
                                    {{ form_errors(form.userInfo.firstname, {
                                        'attr': {
