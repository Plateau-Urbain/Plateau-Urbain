{% extends "::base.html.twig" %}

{% block body %}
<div class="white"> 
        <div class="container"> 
   <div class="bkg-img"></div>
     
    <div class="row top-profil">
        <!-- BEGIN MAIN CONTENT -->
        <div class=" col-sm-12 ">

            <div class="titre-page">
                <h1>Mon profil candidat</h1>
            </div>
           <h6> <a href="{{ path('search_index') }}" class="red"><span class="sub-arrow"><i class="fa fa-square"></i></span>Tous les appels à candidatures</a></h6>
            {# <p>Voir les <a href="{{ path('cgu') }}">Conditions générales d'utilisation</a></p> #}
            
            {% if next is defined and next %}
                <div class="alert alert-info" role="alert">
                    <i class="fa fa-info-circle"></i>
