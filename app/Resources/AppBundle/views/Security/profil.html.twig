                    </div>

                    <span id="four" class="section"></span>
                    <span class="section-title form-four"></span>
                    <div class="form-contener">
                        <h3>Mes documents</h3>
                        <div class="row">
                            <div class="col-sm-12 required-files">
                                <div class="col-sm-6">
                                    <label class="control-label">Mes téléchargements</label>

                                    <dl class="dl-horizontal info-block">

                                        <dd>
                                        Les documents suivants seront attachés à toutes vos candidatures.
                                        Les fichiers complémentaires qui peuvent être joints dans toutes vos candidatures doivent être téléchargés à partir de chaque fiche projet.
                                        </dd>
                                        <br/>
                                         <dd>
                                        Formats autorisés : JPG, GIF, PNG, PDF ou DOC.<br/>
                                        Chaque fichier ne doit pas excéder 10Mo.
                                         </dd>
                                                    
                                    </dl>
                                </div>
                            </div>

                            <div class="col-sm-12">
                                <div class="col-sm-6 required-files">
                                    <ul class="list-unstyled">
                                        {% if form.idcard is defined or app.user.hasDocuments('id') %}
                                        <li class="idcard-file">
                                            {% if app.user.hasDocuments('id') and form.vars.valid %}
                                                <i class="fa fa-check fa-lg"></i>
                                            {% else %}
                                                <i class="fa fa-times fa-lg"></i>
                                            {% endif %}
                                            <label class="required">Pièce d'identité</label>
                                        </li>
                                        {% endif %}
                                    </ul>

                                    <div class="files">
                                        {% if form.idcard is not defined %}
                                            <div class="idcard-file file-infos clearfix">
                                                <div class="clearfix actions overflow">
                                                    {% set file =  app.user.getDocumentsType('id')[0] %}
                                                    <div style="display:inline-block; width:80%">{{ file.originalname }}</div>
                                                    <div style="display:inline-block" class="pull-right">
                                                        <a target="_blank" href="{{ asset(vich_uploader_asset(file, 'file')) }}"><i class="fa fa-eye"></i></a>
                                                        <a href="{{ path('profile_removedocument', { 'id': file.id, 'anchor': 'four' }) }}"><i class="fa fa-trash"></i></a>
                                                    </div>
                                                </div>
                                            </div>
                                        {% elseif form.idcard is defined %}
                                            <div class="idcard-file file-infos clearfix{% if not form.idcard.vars.valid %} has-error{% endif %}">
                                                <div class=" actions overflow ">
                                                    <label class="btn btn-accepted">
                                                        {{ form_widget(form.idcard, {
                                                            'attr': {
                                                                'required': 'required',
                                                                'aria-required': 'true',
                                                                'aria-invalid': form.idcard.vars.errors|length ? 'true' : 'false',
                                                                'aria-describedby': 'idcard-error'
                                                            }
                                                        }) }}
                                                    </label>
                                                </div>
                                                {{ form_errors(form.idcard, {
                                                    'attr': {
                                                        'id': 'idcard-error',
                                                        'role': 'alert',
                                                        'aria-live': 'polite'
                                                    }
                                                }) }}
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                                <div class="col-sm-6 required-files">
                                        <ul class="list-unstyled">
