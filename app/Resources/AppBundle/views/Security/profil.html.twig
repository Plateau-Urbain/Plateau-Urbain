            // Validation à la soumission du formulaire
            $('form').on('submit', function(e) {
                // La validation côté serveur Symfony s'occupe de la validation réelle
                // On ne bloque plus la soumission côté client pour éviter les problèmes de session
                
                // Ajouter un flag pour indiquer qu'une soumission est en cours
                $(this).data('submitting', true);
                
                return true;
            });
            
            // Gestion après soumission du formulaire
            $(window).on('load', function() {
                // Vérifier s'il y a des messages de succès (après soumission)
                const hasSuccessMessage = $('.alert-success').length > 0;
                const wasSubmitting = $('form').data('submitting');
                
                if (hasSuccessMessage && wasSubmitting) {
                    // Faire défiler vers le message de succès en haut de page
                    setTimeout(function() {
                        $('html, body').animate({
                            scrollTop: 0
                        }, 500);
                    }, 100);
                    
                    // Nettoyer le flag
                    $('form').removeData('submitting');
                }
            });
            
            // Nettoyer tous les styles de validation au chargement
            $('.form-group, .social-group, .civility-group').removeClass('has-error');

            // Ne pas initialiser automatiquement la validation au chargement
            // La validation se fera seulement lors de l'interaction utilisateur
        });
    </script>
    
    
