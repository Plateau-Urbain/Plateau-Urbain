{% block javascript %}
    <script>
        // Défilement automatique seulement s'il y a des erreurs de validation visibles
        // Ignorer les messages informatifs (text-muted) et ne garder que les erreurs réelles
        if (document.querySelector('.form-group.has-error .help-block:not(.text-muted)')) {
            setTimeout(function() {
                const firstError = document.querySelector('.form-group.has-error .help-block:not(.text-muted)');
                if (firstError) {
                    firstError.closest('.form-contener').scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            }, 500);
        }
        
        $(document).ready(function() {
            console.log('=== DOCUMENT READY ===');
            console.log('jQuery version:', $.fn.jquery);
            
            // Restaurer les données du formulaire si elles existent
            const savedFormData = sessionStorage.getItem('profileFormData');
            if (savedFormData) {
                console.log('🔄 Restauration des données du formulaire...');
                const formData = JSON.parse(savedFormData);
                
                // Restaurer chaque champ
                Object.keys(formData).forEach(function(fieldName) {
                    const $field = $('[name="' + fieldName + '"]');
                    if ($field.length > 0) {
                        const value = formData[fieldName];
                        const type = $field.attr('type');
                        
                        if (type === 'checkbox' || type === 'radio') {
                            $field.prop('checked', value);
                        } else {
                            $field.val(value);
                        }
                        console.log('✅ Champ restauré:', fieldName, '=', value);
                    }
                });
                
                // Supprimer les données sauvegardées
                sessionStorage.removeItem('profileFormData');
                console.log('✅ Données restaurées et nettoyées');
            }
            // Gestion de la navigation par anchor
            function handleAnchorNavigation() {
                const hash = window.location.hash;
                if (hash) {
                    // Retirer le # du hash
                    const sectionId = hash.substring(1);
                    
                    // Vérifier s'il y a des messages de succès (après soumission du formulaire)
                    const hasSuccessMessage = $('.alert-success').length > 0;
                    
                    // Si c'est après une soumission réussie, faire défiler vers le message de succès
                    if (hasSuccessMessage) {
                        // Faire défiler vers le message de succès en haut de page
                        setTimeout(function() {
                            $('html, body').animate({
                                scrollTop: 0
                            }, 500);
                        }, 100);
                        
                        // Nettoyer l'URL pour éviter la confusion
                        if (history.replaceState) {
                            history.replaceState(null, null, window.location.pathname);
                        }
                        return;
                    }
                    
                    // Trouver l'indicateur correspondant et l'activer
                    const $indicator = $('a.indicator[href="#' + sectionId + '"]');
                    if ($indicator.length > 0) {
                        // Désactiver tous les indicateurs
                        $('a.indicator').removeClass('active');
                        // Activer l'indicateur correspondant
                        $indicator.addClass('active');
                        
                        // Faire défiler vers la section
                        setTimeout(function() {
                            $('#' + sectionId)[0].scrollIntoView({ behavior: 'smooth' });
                        }, 100);
                    }
                }
            }
            
            // Appeler la fonction au chargement
            handleAnchorNavigation();
            
            // Fonction de validation des champs
            function handleFieldValidation(field) {
                const $field = $(field);
                const formGroup = $field.closest('.form-group, .social-group, .civility-group');
                const value = $field.val();
                const isRequired = $field.prop('required') || $field.closest('.required').length > 0;
                
                // Supprimer les anciens messages d'erreur
                formGroup.find('.help-block').remove();
                
                if (isRequired && (!value || value.trim() === '')) {
                    // Champ requis mais vide - afficher l'erreur
                    formGroup.removeClass('has-error').addClass('has-error');
                    formGroup.append('<span class="help-block" role="alert" aria-live="polite">Ce champ est requis</span>');
                } else if (isRequired && value && value.trim() !== '') {
                    // Champ requis et rempli - pas d'erreur, pas de vert
                    formGroup.removeClass('has-error');
                } else if (!isRequired) {
                    // Pour les champs non requis, pas de validation visuelle
                    formGroup.removeClass('has-error');
                }
            }
            
            // Validation en temps réel sur blur et change (sauf les radio buttons)
            $('input, select, textarea').not('input[type="radio"]').on('blur change', function() {
                const $field = $(this);
                
                // Validation spéciale pour les champs texte avec emojis
                if ($field.is('textarea[name*="description"]') || $field.is('textarea[name*="projectDescription"]')) {
                    const formGroup = $field.closest('.form-group');
                    const value = $field.val();
                    const isRequired = $field.prop('required') || $field.closest('.required').length > 0;
                    
                    // Supprimer les anciens messages d'erreur
                    formGroup.find('.help-block').remove();
                    formGroup.removeClass('has-error');
                    
                    if (!value || value.trim() === '') {
                        // Champ vide
                        if (isRequired) {
                            formGroup.append('<span class="help-block" role="alert">Ce champ est requis</span>');
                            formGroup.addClass('has-error');
                            $field.attr('aria-invalid', 'true');
                        } else {
                            $field.attr('aria-invalid', 'false');
                        }
                    } else {
                        // Champ rempli - vérifier les emojis
                        const emojiRegex = /[\u{1F600}-\u{1F64F}]|[\u{1F300}-\u{1F5FF}]|[\u{1F680}-\u{1F6FF}]|[\u{1F1E0}-\u{1F1FF}]|[\u{2600}-\u{26FF}]|[\u{2700}-\u{27BF}]/u;
                        const hasEmojis = emojiRegex.test(value);
                        
                        if (hasEmojis) {
                            formGroup.append('<span class="help-block" role="alert">Le texte ne doit pas contenir d\'emojis</span>');
                            formGroup.addClass('has-error');
                            $field.attr('aria-invalid', 'true');
                        } else {
                            // Texte valide
                            $field.attr('aria-invalid', 'false');
                        }
                    }
                } else {
                    // Validation standard pour les autres champs
                    handleFieldValidation(this);
                }
            });
            
            // Validation spéciale pour les champs téléphone
            $('input[type="tel"]').on('blur change', function() {
                const $field = $(this);
                const formGroup = $field.closest('.form-group');
                const value = $field.val().trim();
                
                // Supprimer les anciens messages d'erreur
                formGroup.find('.help-block').remove();
                
                if (value !== '') {
                    // Regex pour validation téléphone français et international
                    const phoneRegex = /^(\+33\s?[1-9](\s?\d{2}){4}|0[1-9](\s?\d{2}){4})$/;
                    
                    if (!phoneRegex.test(value)) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block" role="alert" aria-live="polite">Le format du téléphone n\'est pas valide. Utilisez le format français (01 23 45 67 89) ou international (+33 1 23 45 67 89).</span>');
                    } else {
                        formGroup.removeClass('has-error');
                    }
                } else {
                    // Vérifier si c'est le téléphone personnel (obligatoire)
                    if ($field.attr('name') && $field.attr('name').includes('phone') && !$field.attr('name').includes('company')) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block" role="alert" aria-live="polite">Le téléphone est obligatoire.</span>');
                    } else {
                        formGroup.removeClass('has-error');
                    }
                }
            });
            
            // Validation spéciale pour le champ SIRET
            $('input[name*="siret"]').on('blur change', function() {
                const $field = $(this);
                const formGroup = $field.closest('.form-group');
                const value = $field.val().trim();
                
                // Supprimer les anciens messages d'erreur
                formGroup.find('.help-block').remove();
                
                if (value !== '') {
                    // Vérifier le format SIRET avec ou sans espaces
                    if (!/^(\d{3}\s?){4}\d{2}$/.test(value)) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block" role="alert" aria-live="polite">Le SIRET doit contenir exactement 14 chiffres. Format accepté : 123 456 789 01234</span>');
                    } else {
                        formGroup.removeClass('has-error');
                    }
                } else {
                    formGroup.removeClass('has-error');
                }
            });
            
            // Validation spéciale pour le champ code postal
            $('input[name*="zipcode"]').on('blur change', function() {
                const $field = $(this);
                const formGroup = $field.closest('.form-group');
                const value = $field.val().trim();
                
                // Supprimer les anciens messages d'erreur
                formGroup.find('.help-block').remove();
                
                if (value !== '') {
                    // Vérifier que c'est exactement 5 chiffres
                    if (!/^\d{5}$/.test(value)) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block" role="alert" aria-live="polite">Le code postal doit contenir exactement 5 chiffres.</span>');
                    } else {
                        formGroup.removeClass('has-error');
                    }
                } else {
                    // Champ obligatoire mais vide
                    formGroup.addClass('has-error');
                    formGroup.append('<span class="help-block" role="alert" aria-live="polite">Le code postal est obligatoire.</span>');
                }
            });
            
            // Validation spéciale pour le téléphone mobile (obligatoire)
            $('input[name*="companyMobile"]').on('blur change', function() {
                const $field = $(this);
                const formGroup = $field.closest('.form-group');
                const value = $field.val().trim();
                
                // Supprimer les anciens messages d'erreur
                formGroup.find('.help-block').remove();
                
                if (value !== '') {
                    // Regex pour validation téléphone français et international
                    const phoneRegex = /^(\+33\s?[1-9](\s?\d{2}){4}|0[1-9](\s?\d{2}){4})$/;
                    
                    if (!phoneRegex.test(value)) {
                        formGroup.addClass('has-error');
                        formGroup.append('<span class="help-block" role="alert" aria-live="polite">Le format du téléphone n\'est pas valide. Utilisez le format français (06 12 34 56 78) ou international (+33 6 12 34 56 78).</span>');
                    } else {
                        formGroup.removeClass('has-error');
                    }
                } else {
                    // Champ obligatoire mais vide
                    formGroup.addClass('has-error');
                    formGroup.append('<span class="help-block" role="alert" aria-live="polite">Le téléphone mobile est obligatoire.</span>');
                }
            });
            
            // Validation spéciale pour les groupes de radio (civilité)
            $('input[name*="civility"]').on('change', function() {
                const civilityGroup = $('.civility-group');
                civilityGroup.find('.help-block').remove();
                
                if ($('input[name*="civility"]:checked').length > 0) {
                    civilityGroup.removeClass('has-error');
                } else {
                    civilityGroup.addClass('has-error');
                    civilityGroup.append('<span class="help-block" role="alert" aria-live="polite">Veuillez sélectionner votre civilité</span>');
