                                    }) }}
                                </div>
                                <div class="col-sm-6 form-group{% if form.userInfo.lastname.vars.errors|length %} has-error{% endif %}">
                                    {{ form_label(form.userInfo.lastname, null, {'label_attr': {'class': 'required'}}) }}
                                    {{ form_widget(form.userInfo.lastname, {
                                        'attr': {
                                            'required': 'required',
                                            'aria-required': 'true',
                                            'aria-invalid': form.userInfo.lastname.vars.errors|length ? 'true' : 'false',
                                            'aria-describedby': 'lastname-error',
                                            'data-error-message': 'Veuillez renseigner votre nom'
                                        }
                                    }) }}
                                    {{ form_errors(form.userInfo.lastname, {
                                        'attr': {
                                            'id': 'lastname-error',
                                            'role': 'alert',
                                            'aria-live': 'polite'
