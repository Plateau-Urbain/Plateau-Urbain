                const $link = $(this);
                
                // Vérifier si c'est un lien de suppression (par URL ou par icône)
                const isDeleteLink = (href && href.includes('profile_removedocument')) || 
                                   $link.find('i.fa-trash').length > 0;
                
                if (isDeleteLink) {
                    console.log('=== LIEN DE SUPPRESSION DÉTECTÉ ===');
                    console.log('URL:', href);
                    
                    e.preventDefault();
                    e.stopPropagation();
                    console.log('✅ Rechargement empêché');
                    
                    // Confirmation de suppression
                    if (!confirm('Êtes-vous sûr de vouloir supprimer ce document ?')) {
                        return false;
                    }
                    
                    // Sauvegarder les données du formulaire
                    console.log('💾 Sauvegarde des données du formulaire...');
                    const formData = new FormData($('form')[0]);
                    const savedData = {};
                    
                    // Sauvegarder tous les champs de saisie
                    $('input, select, textarea').each(function() {
                        const $field = $(this);
                        const name = $field.attr('name');
                        const type = $field.attr('type');
                        
                        if (name && type !== 'file' && type !== 'submit' && type !== 'button') {
                            if (type === 'checkbox' || type === 'radio') {
                                savedData[name] = $field.is(':checked');
                            } else {
                                savedData[name] = $field.val();
                            }
                        }
                    });
                    
                    console.log('✅ Données sauvegardées:', Object.keys(savedData).length, 'champs');
                    
                    const $link = $(this);
                    const $parentLi = $(this).closest('li');
                    const $parentDiv = $(this).closest('.file-infos');
                    
                    console.log('Parent li trouvé:', $parentLi.length);
                    console.log('Parent div trouvé:', $parentDiv.length);
                    
                    // Désactiver le lien pendant la requête
                    $link.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i>');
                    
                    // Suppression en AJAX
                    $.ajax({
                        url: href,
                        type: 'GET',
                        success: function(response) {
                            console.log('✅ Document supprimé avec succès');
                            
                            // Stocker les données dans sessionStorage pour les restaurer après rechargement
                            sessionStorage.setItem('profileFormData', JSON.stringify(savedData));
                            console.log('💾 Données stockées dans sessionStorage');
                            
                            // Recharger la page pour afficher les champs d'upload
                            console.log('🔄 Rechargement de la page...');
