{% extends "::base.html.twig" %}

{% block body %}
<div class="white">
        <div class="container">
<div class="bkg-img"></div>

<div class="row top-profil">
    <!-- BEGIN MAIN CONTENT -->
    <div class=" col-sm-12 ">

        <div class="titre-page">
            <h1>
                {{ 'Déposer ma candidature' }}
            </h1>
        </div>
        
        
        <!-- Pop-up d'avertissement -->
        <div id="depublished-warning-modal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="depublished-warning-title" aria-hidden="true">
            <div class="modal-dialog modal-lg" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title" id="depublished-warning-title">
                            <i class="fa fa-exclamation-triangle text-warning"></i>
                            Espace temporairement dépublié
                        </h4>
                    </div>
                    <div class="modal-body">
                        <p>Cet espace a été temporairement suspendu par le propriétaire pour modification.</p>
                        <ul>
                            <li><strong>Vous pouvez continuer à remplir votre candidature</strong> et l'enregistrer en brouillon</li>
                            <li><strong>Vous ne pourrez pas soumettre définitivement</strong> votre candidature tant que l'espace n'est pas republié</li>
                            <li><strong>Une fois l'espace republié</strong>, vous pourrez compléter et soumettre votre candidature depuis "Mes candidatures"</li>
                            <li><strong>Vous serez notifié</strong> quand l'espace sera de nouveau disponible</li>
                        </ul>
                        <div class="alert alert-warning">
                            <strong>Important :</strong> Le bouton "Soumettre" est désactivé. Utilisez le bouton "Enregistrer en brouillon" pour sauvegarder votre travail.
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-line-19 btn-grey" data-dismiss="modal">
                            J'ai compris
                        </button>
                    </div>
                </div>
            </div>
        </div>
        {% if app.user %}
        <h6>
            <i class="fa-solid fa-chevron-right"></i> Certaines informations ont été mises à jour via les informations de votre <a href="{{ path('security_profil') }}" class="mailto">profil</a>.
        </h6>
        {% endif %}
        {% if not app.user %}
        <h6>
            <i class="fa-solid fa-chevron-right"></i> Si vous possédez déjà un compte, connectez-vous pour récupérer les informations de <a href="{{ path('security_profil') }}" class="mailto">votre profil</a>.
        </h6>
        {% endif %}

        <div class="pu-col-container content-block">
            <div class="row">
                {{ form_start(form, {'attr' : {'class' : 'col-md-12 form-apply', 'role': 'form', 'aria-label': 'Formulaire de candidature'} } ) }}
                {{ form_errors(form, {'attr': {'role': 'alert', 'aria-live': 'polite'}}) }}
                
                {# Affichage des erreurs de validation côté serveur #}
                {% if not form.vars.valid and form.vars.submitted %}
                    <div class="alert alert-danger" role="alert">
                        {# Afficher toutes les erreurs du formulaire (incluant les erreurs des champs de documents) #}
                        {% for error in form.vars.errors %}
                            <div>{{ error.message }}</div>
                        {% endfor %}
                        
                        {# Afficher les erreurs des champs de documents spécifiquement #}
                        {% for document in space.documents %}
                            {% set fieldName = 'document_' ~ document.id %}
                            {% if form[fieldName] is defined %}
                                {% for error in form[fieldName].vars.errors %}
                                    <div>{{ error.message }}</div>
                                {% endfor %}
                            {% endif %}
                        {% endfor %}
                        
                        {# Afficher les erreurs des autres champs du formulaire #}
                        {% for child in form %}
                            {% if child.vars.errors is defined and child.vars.errors|length > 0 %}
                                {% for error in child.vars.errors %}
                                    <div>{{ error.message }}</div>
                                {% endfor %}
                            {% endif %}
                            
                            {# Parcourir les enfants des champs (pour les champs imbriqués) #}
                            {% for grandChild in child %}
                                {% if grandChild.vars.errors is defined and grandChild.vars.errors|length > 0 %}
                                    {% for error in grandChild.vars.errors %}
                                        <div>{{ error.message }}</div>
                                    {% endfor %}
                                {% endif %}
                                
                                {# Parcourir les arrière-petits-enfants #}
                                {% for greatGrandChild in grandChild %}
                                    {% if greatGrandChild.vars.errors is defined and greatGrandChild.vars.errors|length > 0 %}
                                        {% for error in greatGrandChild.vars.errors %}
                                            <div>{{ error.message }}</div>
                                        {% endfor %}
                                    {% endif %}
                                {% endfor %}
                            {% endfor %}
                        {% endfor %}
                    </div>
                {% endif %}

                <div id="js-form-space" role="group" aria-label="Étapes du formulaire">

                    <div class="row">
                        <div class=" col-xs-1 bkg ">
                            <ul role="tablist">
                                <li role="tab" aria-controls="one" aria-selected="true">
                                    <a class="indicator active" href="#one" aria-label="Étape 1: Mes informations"></a>
                                </li>
                                <li role="tab" aria-controls="two" aria-selected="false">
                                    <a class="indicator" href="#two" aria-label="Étape 2: Ma structure"></a>
                                </li>
                                <li role="tab" aria-controls="three" aria-selected="false">
                                    <a class="indicator" href="#three" aria-label="Étape 3: Réseaux sociaux"></a>
                                </li>
                                <li role="tab" aria-controls="four" aria-selected="false">
                                    <a class="indicator" href="#four" aria-label="Étape 4: Mes souhaits"></a>
                                </li>
                                <li role="tab" aria-controls="five" aria-selected="false">
                                    <a class="indicator" href="#five" aria-label="Étape 5: Mes documents"></a>
                                </li>
                            </ul>
                        </div>

                        <div class="main col-xs-10">
                            <div id="one" class="section" role="tabpanel" aria-labelledby="section-info-title">
                                <span class="section-title form-one"></span>
                                <div class="form-contener vert">
                                    <h3 id="section-info-title">Mes informations</h3>

                                    <div class="row">
                                        <div class="col-sm-6 inline-controls form-group civility-group">
                                            {{ form_label(form.projectHolder.userInfo.civility) }}
                                            {{ form_widget(form.projectHolder.userInfo.civility, {
                                                'label_attr': { 'class': 'radio-inline' },
                                                'attr': {
                                                    'aria-required': 'true',
                                                    'aria-invalid': form_errors(form.projectHolder.userInfo.civility) ? 'true' : 'false',
                                                    'aria-describedby': 'civility-error'
                                                }
                                            }) }}
                                            {{ form_errors(form.projectHolder.userInfo.civility, {
                                                'attr': {
                                                    'id': 'civility-error',
                                                    'role': 'alert',
                                                    'aria-live': 'polite'
                                                }
                                            }) }}
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-6 form-group">
                                            {{ form_label(form.projectHolder.userInfo.firstname, null, {'label_attr': {'class': 'required'}}) }}
                                            {{ form_widget(form.projectHolder.userInfo.firstname, {
                                                'attr': {
                                                    'aria-required': 'true',
                                                    'aria-invalid': form_errors(form.projectHolder.userInfo.firstname) ? 'true' : 'false',
                                                    'aria-describedby': 'firstname-error'
                                                }
                                            }) }}
                                            {{ form_errors(form.projectHolder.userInfo.firstname, {
                                                'attr': {
                                                    'id': 'firstname-error',
                                                    'role': 'alert',
                                                    'aria-live': 'polite'
                                                }
                                            }) }}
                                        </div>
                                        <div class="col-sm-6 form-group">
                                            {{ form_label(form.projectHolder.userInfo.lastname, null, {'label_attr': {'class': 'required'}}) }}
                                            {{ form_widget(form.projectHolder.userInfo.lastname, {
                                                'attr': {
                                                    'aria-required': 'true',
                                                    'aria-invalid': form_errors(form.projectHolder.userInfo.lastname) ? 'true' : 'false',
                                                    'aria-describedby': 'lastname-error'
                                                }
                                            }) }}
                                            {{ form_errors(form.projectHolder.userInfo.lastname, {
                                                'attr': {
                                                    'id': 'lastname-error',
                                                    'role': 'alert',
                                                    'aria-live': 'polite'
                                                }
                                            }) }}
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-6 form-group">
                                            {{ form_label(form.projectHolder.userInfo.birthday) }}
                                            {{ form_widget(form.projectHolder.userInfo.birthday, {
                                                'attr': {
                                                    'aria-invalid': form_errors(form.projectHolder.userInfo.birthday) ? 'true' : 'false',
                                                    'aria-describedby': 'birthday-error'
                                                }
                                            }) }}
                                            {{ form_errors(form.projectHolder.userInfo.birthday, {
                                                'attr': {
                                                    'id': 'birthday-error',
                                                    'role': 'alert',
                                                    'aria-live': 'polite'
                                                }
                                            }) }}
                                        </div>
                                        <div class="col-sm-6 form-group">
                                            {{ form_label(form.projectHolder.userInfo.phone, null, {'label_attr': {'class': 'required'}}) }}
                                            {{ form_widget(form.projectHolder.userInfo.phone, {
                                                'attr': {
                                                    'aria-required': 'true',
                                                    'aria-invalid': form_errors(form.projectHolder.userInfo.phone) ? 'true' : 'false',
                                                    'aria-describedby': 'phone-error'
                                                }
                                            }) }}
                                            {{ form_errors(form.projectHolder.userInfo.phone, {
                                                'attr': {
                                                    'id': 'phone-error',
                                                    'role': 'alert',
                                                    'aria-live': 'polite'
                                                }
                                            }) }}
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-12 form-group">
                                            {{ form_label(form.projectHolder.userInfo.email, null, {'label_attr': {'class': 'required'}}) }}
                                            {{ form_widget(form.projectHolder.userInfo.email, {
                                                'attr': {
                                                    'aria-required': 'true',
                                                    'aria-invalid': form_errors(form.projectHolder.userInfo.email) ? 'true' : 'false',
                                                    'aria-describedby': 'email-error'
                                                }
                                            }) }}
                                            {{ form_errors(form.projectHolder.userInfo.email, {
                                                'attr': {
                                                    'id': 'email-error',
                                                    'role': 'alert',
                                                    'aria-live': 'polite'
                                                }
                                            }) }}
                                        </div>
                                    </div>
                                    {% if not app.user %}
                                    <div class="row">
                                        <div class="col-sm-6 form-group">
                                            {{ form_row(form.projectHolder.userInfo.plainPassword.first) }}
                                        </div>
                                        <div class="col-sm-6 form-group">
                                            {{ form_row(form.projectHolder.userInfo.plainPassword.second) }}
                                        </div>
                                    </div>
                                    {% endif %}
                                    <div class="row">
                                        <div class="col-sm-12 form-group">
                                            {{ form_row(form.projectHolder.userInfo.description, {'attr': {'placeholder': 'Décrivez-vous en quelques mots (emojis non autorisés)'}}) }}
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div id="two" class="section">
                                <span class="section-title form-two"></span>
                                <div class="form-contener vert">
                                    <h3>Ma structure</h3>

                                    <div class="row">
                                        <div class="col-sm-6 form-group">
                                            {{ form_row(form.projectHolder.companyInfo.company) }}
                                        </div>
                                        <div class="col-sm-6 form-group">
                                            {{ form_row(form.projectHolder.companyInfo.companyStatus) }}
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-sm-6  form-group">
                                            {{ form_row(form.projectHolder.companyInfo.companyCreationDate) }}
                                        </div>
                                        <div class="col-sm-6  form-group">
                                            {{ form_row(form.projectHolder.companyInfo.siret)}}
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-sm-12 form-group">
                                            {{ form_row(form.projectHolder.companyInfo.address)}}
                                        </div>
                                        <div class="col-sm-6 form-group">
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-sm-6 form-group">
                                            {{ form_label(form.projectHolder.companyInfo.zipcode, null, {'label_attr': {'class': 'required'}}) }}
                                            {{ form_widget(form.projectHolder.companyInfo.zipcode, {'attr': {'class': 'form-control', 'pattern': '[0-9]{5}', 'maxlength': '5', 'title': 'Le code postal doit contenir exactement 5 chiffres'}}) }}
                                            {{ form_errors(form.projectHolder.companyInfo.zipcode) }}
                                        </div>
                                        <div class="col-sm-6 form-group">
                                            {{ form_row(form.projectHolder.companyInfo.city)}}
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-sm-6 form-group">
                                            {{ form_row(form.projectHolder.companyInfo.companyPhone)}}
                                        </div>
                                        <div class="col-sm-6 form-group">
                                            {{ form_row(form.projectHolder.companyInfo.companyMobile) }}
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-sm-12 form-group">
                                            {{ form_row(form.projectHolder.companyInfo.companyDescription, {'attr': {'placeholder': 'Présentez votre structure (emojis non autorisés)'}}) }}
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-sm-6 form-group">
                                            {{ form_row(form.projectHolder.companyInfo.companyEffective)}}
                                        </div>
                                        <div class="col-sm-6 form-group">
                                            {{ form_row(form.projectHolder.companyInfo.companyStructures)}}
                                        </div>
                                    </div>

                                    <div class="row" >
                                        <div class="col-sm-6 form-group">
                                            {{ form_row(form.projectHolder.companyInfo.companySite)}}
                                        </div>
                                        <div class="col-sm-6 form-group">
                                            {{ form_row(form.projectHolder.companyInfo.companyBlog)}}
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div id="three" class="section">
                                <span class="section-title form-three"></span>
                                <div class="form-contener vert">
                                    <h3>Réseaux sociaux</h3>
                                    <div class="row" >
                                        <div class="col-sm-6 form-group">
                                            <div class="input-group social-group">
                                                <span class="input-group-addon"><i class="fa-brands fa-facebook-f fa-lg"></i></span>
                                                {{ form_widget(form.projectHolder.facebookUrl) }}
                                                {{ form_errors(form.projectHolder.facebookUrl) }}
                                            </div>
                                        </div>

                                        <div class="col-sm-6 form-group">
                                            <div class="input-group social-group">
                                                <span class="input-group-addon"><i class="fa-brands fa-twitter fa-lg"></i></span>
                                                {{ form_widget(form.projectHolder.twitterUrl) }}
                                                {{ form_errors(form.projectHolder.twitterUrl) }}
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row" >
                                        <div class="col-sm-6 form-group">
                                            <div class="input-group social-group">
                                                <span class="input-group-addon"><i class="fa-brands fa-linkedin-in fa-lg"></i></span>
                                                {{ form_widget(form.projectHolder.linkedinUrl) }}
                                                {{ form_errors(form.projectHolder.linkedinUrl) }}
                                            </div>
                                        </div>

                                        <div class="col-sm-6 form-group">
                                            <div class="input-group social-group">
                                                <span class="input-group-addon"><i class="fa-brands fa-instagram fa-lg"></i></span>
                                                {{ form_widget(form.projectHolder.instagramUrl) }}
                                                {{ form_errors(form.projectHolder.instagramUrl) }}
                                            </div>
                                        </div>
                                    </div>

                                    <div class="row" >
                                        <div class="col-sm-6 form-group">
                                            <div class="input-group social-group">
                                                <span class="input-group-addon"><i class="fa-brands fa-youtube fa-lg"></i></span>
                                                {{ form_widget(form.projectHolder.googleUrl) }}
                                                {{ form_errors(form.projectHolder.googleUrl) }}
                                            </div>
                                        </div>

                                        <div class="col-sm-6 form-group">
                                            <div class="input-group social-group">
                                                <span class="input-group-addon"><i class="fa-brands fa-tiktok fa-lg"></i></span>
                                                {{ form_widget(form.projectHolder.otherUrl) }}
                                                {{ form_errors(form.projectHolder.otherUrl) }}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div id="four" class="section">
                                <span class="section-title form-four"></span>
                                <div class="form-contener vert">
                                        <h3>Mes souhaits</h3>
                                        <div class="row">
                                            <div class="col-sm-6 form-group">
                                                {{ form_label(form.name, null, {'label_attr': {'class': 'required'}}) }}
                                                {{ form_widget(form.name, {
                                                    'attr': {
                                                        'required': 'required',
                                                        'aria-required': 'true',
                                                        'aria-invalid': form_errors(form.name) ? 'true' : 'false',
                                                        'aria-describedby': 'name-error'
                                                    }
                                                }) }}
                                                {{ form_errors(form.name, {
                                                    'attr': {
                                                        'id': 'name-error',
                                                        'role': 'alert',
                                                        'aria-live': 'polite'
                                                    }
                                                }) }}
                                            </div>
                                            <div class="col-sm-6 form-group">
                                                {{ form_row(form.category, {
                                                    'label_attr': {'class': 'required'},
                                                    'attr': {
                                                        'class': 'form-control',
                                                        'required': 'required',
                                                        'data-error-message': 'Veuillez sélectionner un type de projet'
                                                    }
                                                }) }}
                                            </div>

                                        </div>

                                        <div class="row">
                                            <div class="col-sm-6 form-group">
                                                {{ form_row(form.wishedSize) }}
                                            </div>

                                            <div class="col-sm-6 form-group{% if (form.lengthOccupation.vars.errors is defined and form.lengthOccupation.vars.errors|length) or (form.lengthTypeOccupation.vars.errors is defined and form.lengthTypeOccupation.vars.errors|length) %} has-error{% endif %}">
                                                {{ form_label(form.lengthOccupation, null, {'label_attr' : {'class' : app.user ? 'inline-label' : 'inline-label required'}}) }}
                                                <div class="row">
                                                    <div class="col-sm-6">
                                                        {{ form_widget(form.lengthOccupation, {
                                                            'attr': {
                                                                'required': not app.user ? 'required' : false,
                                                                'aria-required': not app.user ? 'true' : 'false',
                                                                'aria-invalid': form_errors(form.lengthOccupation) ? 'true' : 'false',
                                                                'aria-describedby': 'lengthOccupation-error',
                                                                'data-error-message': 'Veuillez indiquer la durée d\'occupation'
                                                            }
                                                        }) }}
                                                        {{ form_errors(form.lengthOccupation, {
                                                            'attr': {
                                                                'id': 'lengthOccupation-error',
                                                                'role': 'alert',
                                                                'aria-live': 'polite'
                                                            }
                                                        }) }}
                                                    </div>
                                                    <div class="col-sm-6">
                                                        {{ form_widget(form.lengthTypeOccupation, {
                                                            'attr': {
                                                                'required': not app.user ? 'required' : false,
                                                                'aria-required': not app.user ? 'true' : 'false',
                                                                'aria-invalid': form_errors(form.lengthTypeOccupation) ? 'true' : 'false',
                                                                'aria-describedby': 'lengthTypeOccupation-error',
                                                                'data-error-message': 'Veuillez sélectionner l\'unité de temps'
                                                            }
                                                        }) }}
                                                        {{ form_errors(form.lengthTypeOccupation, {
                                                            'attr': {
                                                                'id': 'lengthTypeOccupation-error',
                                                                'role': 'alert',
                                                                'aria-live': 'polite'
                                                            }
                                                        }) }}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>



                                        <div class="row">
                                            <div class="col-sm-6 form-group">
                                                {{ form_label(form.startOccupation, null, {'label_attr': {'class': 'inline-label required'}}) }}
                                                {{ form_widget(form.startOccupation, {
                                                    'attr': {
                                                        'required': 'required',
                                                        'aria-required': 'true',
                                                        'aria-invalid': form_errors(form.startOccupation) ? 'true' : 'false',
                                                        'aria-describedby': 'startOccupation-error',
                                                        'data-error-message': 'Veuillez indiquer une date d\'entrée souhaitée'
                                                    }
                                                }) }}
                                                {{ form_errors(form.startOccupation, {
                                                    'attr': {
                                                        'id': 'startOccupation-error',
                                                        'role': 'alert',
                                                        'aria-live': 'polite'
                                                    }
                                                }) }}
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-sm-12 form-group first{% if form.description.vars.errors is defined and form.description.vars.errors|length %} has-error{% endif %}">
                                                {{ form_label(form.description, null, {'label_attr': {'class': 'required'}}) }}
                                                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Décrivez votre projet en détail (emojis non autorisés)'}}) }}
                                                {{ form_errors(form.description) }}
                                            </div>
                                            <div class="col-sm-12 form-group">
                                                {{ form_row(form.openToGlobalProject, { 'attr': { 'data-checkbox-toggle': '#toggle_' ~ form.contribution.vars.id } }) }}
                                            </div>
                                            <div class="col-sm-12 form-group" id="toggle_{{ form.contribution.vars.id }}">
                                                {{ form_row(form.contribution) }}
                                            </div>
                                            <div class="col-sm-12 form-group">
                                                {{ form_row(form.devenirSocietaire) }}
                                                
                                            </div>

                                            <div class=" files">
                                                <div class="col-sm-12 form-group">
                                                    {% if space.getDocuments() | length > 0 %}
                                                   <span class="img-docs"></span> <h6 class="docs">{{space.getDocuments() | length}} fichier{% if space.getDocuments() | length > 1%}s{% endif %} à joindre à votre candidature <span class="red">*</span></h6>
                                                    {% endif %}
                                                </div>

                                                {% for document in space.documents %}
                                                <div class="col-sm-8 offset-4 form-group arrow">
                                                   <i class="fa fa-arrow-right fa-lg"></i>&nbsp;<label>{{document.name}}</label>
                                                    {% if form["document_#{document.id}"] is not defined %}
                                                        <div class="file-infos clearfix" >
                                                            <div class="actions overflow">
                                                                {% set file = application.getFilesType(document.id).0 %}
                                                                <div style="display:inline-block; width:90%; text-overflow:ellipsis;overflow:hidden">{{ file.filename }}</div>
                                                                <div style="width: 10%" class="clearfix pull-right">
                                                                    <a target="_blank" href="{{ asset(vich_uploader_asset(file, 'file')) }}"><i class="fa fa-eye"></i></a>
                                                                    {% if file.id %}<a href="{{ path('space_removefile', { 'id': file.id, 'service': app.request.uri }) }}"><i class="fa fa-trash"></i></a>{% endif %}
                                                                </div>
                                                            </div>
                                                        </div>
                                                    {% else %}
                                                        <div class="file-infos clearfix" >
                                                            <div class="actions overflow">
                                                                <label class="small">
                                                                    {{ form_widget(attribute(form, "document_#{document.id}")) }}
                                                                </label>
                                                            </div>
                                                        </div>
                                                        {{ form_errors(form["document_#{document.id}"]) }}
                                                    {% endif %}
                                                </div>
                                                {% endfor %}

                                                {# Conteneur pour les erreurs de fichiers #}
                                                <div id="file-validation-errors" class="col-sm-12" style="display: none;"></div>

                                                <div class="col-sm-12 ">
                                                    <label class="control-label">Joindre des fichiers supplémentaires à cette candidature</label>
                                                    {% if form.vars.data.getFilesType(null) | length > 0 %}
                                                    <dl class="dl-horizontal  info-block">
                                                        <dd>Les documents suivants seront seulement attachés à la candidature de cet espace. Les fichiers qui peuvent être joints dans toutes vos candidatures doivent être téléchargés dans la section "Documents".</dd>
                                                    </dl>
                                                    {% endif %}
                                                </div>

