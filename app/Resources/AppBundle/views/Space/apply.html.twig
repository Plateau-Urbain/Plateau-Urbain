{% block javascript %}
    <script>
        $(document).ready(function() {
            // Variable globale pour empêcher l'affichage multiple du pop-up
            let modalAlreadyShown = false;
            
            // Fonction pour afficher le pop-up d'avertissement
            function showDepublishedModal() {
                if (modalAlreadyShown) return;
                modalAlreadyShown = true;
                $('#depublished-warning-modal').modal({
                    backdrop: false,
                    keyboard: true
                });
            }
            
            // Afficher le pop-up d'avertissement si l'espace est dépublié au chargement
            {% if not space.isEnabled() and not space.isClosed() %}
            // Attendre 3 secondes puis afficher le pop-up pendant la saisie
                    setTimeout(function() {
                showDepublishedModal();
            }, 3000);
            {% endif %}
            
            // Vérifier périodiquement l'état de l'espace pendant la saisie
            let spaceCheckInterval = null;
            
            function checkSpaceStatus() {
                if (modalAlreadyShown) return;
                
                // Ne pas vérifier si l'utilisateur est en train de soumettre le formulaire
                if ($('form').data('submitting')) {
                    return;
                }
                
                $.ajax({
                    url: '{{ path('space_check_status', {'id': space.id}) }}',
                    type: 'GET',
                    dataType: 'json',
                    success: function(data) {
                        if (data.isDepublished && !data.isClosed) {
                            showDepublishedModal();
                            // Arrêter la vérification périodique
                            if (spaceCheckInterval) {
                                clearInterval(spaceCheckInterval);
                            }
                        }
                    },
                    error: function() {
                        // En cas d'erreur, continuer la vérification
                        console.log('Erreur lors de la vérification de l\'état de l\'espace');
                                }
                            });
                        }
            
            // Démarrer la vérification périodique après 5 secondes (pour laisser le temps à l'utilisateur de commencer à saisir)
            setTimeout(function() {
                spaceCheckInterval = setInterval(checkSpaceStatus, 10000); // Vérifier toutes les 10 secondes
            }, 5000);
            
            // Désactiver le bouton Soumettre si l'espace est dépublié
            {% if not space.isEnabled() and not space.isClosed() %}
            $(document).ready(function() {
                const submitButton = $('input[name="appbundle_application[submit]"], button[name="appbundle_application[submit]"]');
                if (submitButton.length) {
                    submitButton.prop('disabled', true);
                    submitButton.attr('title', 'L\'espace doit être publié pour soumettre la candidature');
                    submitButton.addClass('disabled');
                }
            });
            {% endif %}
            
            // Force hide Chosen container for category if present
            (function hideChosenForCategory() {
                var $native = $('#appbundle_application_category');
                var $chosen = $('#appbundle_application_category_chosen, #appbundle_application_category_chzn, #appbundle_application_category + .chzn-container, #appbundle_application_category + .chosen-container');
                if ($chosen.length) {
                    $chosen.hide();
                }
                // also ensure native is visible
                if ($native.length) {
                    $native.show();
                }
            })();
            // Fonction pour gérer l'affichage des erreurs
            function handleFieldValidation(field) {
                const formGroup = field.closest('.form-group');
                const value = field.val();
                const isRequired = field.prop('required') || field.attr('required') === 'required' || field.closest('.required').length > 0;
                const fieldName = field.attr('name') || field.attr('id');
                
                // Supprimer les anciens messages d'erreur
                formGroup.find('.help-block').remove();
                
                if (isRequired && (!value || value.trim() === '')) {
                    // Champ requis mais vide - pas de vert, pas de rouge (attendre la soumission)
                    formGroup.removeClass('is-valid').removeClass('has-error');
                } else if (isRequired && value && value.trim() !== '') {
                    // Seulement vert si le champ est requis ET correctement rempli
                    formGroup.removeClass('has-error').addClass('is-valid');
                } else if (!isRequired) {
                    // Pour les champs non requis, pas de validation visuelle
                    formGroup.removeClass('has-error is-valid');
                }
                
                // Mettre à jour les indicateurs d'étape
                updateStepIndicators();
                
                return isRequired && (!value || value.trim() === ''); // Retourne true s'il y a une erreur
            }

            // Fonction pour mettre à jour les indicateurs d'étape
            function updateStepIndicators() {
                $('.section').each(function() {
                    const section = $(this);
                    const hasErrors = section.find('.has-error').length > 0;
                    const indicator = $(`a[href="#${section.attr('id')}"]`);
                    
                    if (hasErrors) {
                        indicator.addClass('has-error');
                    } else {
                        indicator.removeClass('has-error');
                                }
                            });
                        }

            // Validation en temps réel pour tous les champs
            $('input, select, textarea').on('blur change', function() {
                const $field = $(this);
                
                // Ne pas valider les champs de durée d'occupation si l'utilisateur est connecté
                if ($field.closest('.form-group').find('label.required').length > 0) {
                    handleFieldValidation($field);
                } else if (!$field.is('#appbundle_application_lengthOccupation, #appbundle_application_lengthTypeOccupation')) {
                    handleFieldValidation($field);
                }
                
                // Ajouter la coche verte pour tous les champs valides
                updateFieldValidationIcon($field);
            });
            
            // Fonction pour mettre à jour l'icône de validation
            function updateFieldValidationIcon($field) {
                const formGroup = $field.closest('.form-group');
                const value = $field.val();
                const isRequired = $field.prop('required') || $field.attr('required') === 'required' || $field.closest('.required').length > 0;


                // Pour les selects, vérifier si une option valide est sélectionnée
                if ($field.is('select')) {
                    const isValidSelect = value && value !== '' && value !== '0' && !$field.find('option:selected').text().includes('Sélectionner');
                    if (isRequired && isValidSelect) {
                        // Seulement vert si requis ET valide
                        formGroup.addClass('is-valid').removeClass('has-error');
                    } else if (isRequired && !isValidSelect && value && value.trim() !== '') {
                        // Rouge seulement si une valeur invalide est sélectionnée
                        formGroup.addClass('has-error').removeClass('is-valid');
                    } else {
                        // Pas de validation visuelle par défaut
                        formGroup.removeClass('has-error is-valid');
                    }
                } else {
                    // Pour les autres champs
                    if (isRequired && value && value.trim() !== '') {
                        // Seulement vert si requis ET rempli
                        formGroup.addClass('is-valid').removeClass('has-error');
                    } else {
                        // Pas de validation visuelle par défaut
                        formGroup.removeClass('has-error is-valid');
                    }
                }
            }

            // Validation spéciale pour la date d'entrée
            $('#appbundle_application_startOccupation').on('change', function() {
                const value = $(this).val();
                const formGroup = $(this).closest('.form-group');
                
                if (!value) {
                    formGroup.addClass('has-error').removeClass('is-valid');
                    if (formGroup.find('.help-block').length === 0) {
                        formGroup.append('<span class="help-block" role="alert">Veuillez indiquer une date d\'entrée souhaitée</span>');
                    }
                } else {
                    formGroup.removeClass('has-error').addClass('is-valid');
                    formGroup.find('.help-block').remove();
                }
            });

            // Gestion spéciale pour les fichiers
            $('.file-infos input[type="file"]').on('change', function() {
                const fileInfo = $(this).closest('.file-infos');
                const file = this.files[0];
                
                // Supprimer les anciens messages d'erreur
                fileInfo.find('.help-block').remove();
                
                if (file) {
                    // Vérifier la taille du fichier (10Mo max)
                    if (file.size > 10 * 1024 * 1024) {
                        fileInfo.addClass('has-error');
                        fileInfo.append('<span class="help-block" role="alert" aria-live="polite">Le fichier est trop volumineux (maximum 10Mo)</span>');
                    } else {
                        fileInfo.removeClass('has-error');
                    }
                } else {
                    // Si aucun fichier sélectionné et que le champ est requis
                    if ($(this).prop('required')) {
                        fileInfo.addClass('has-error');
                        fileInfo.append('<span class="help-block" role="alert" aria-live="polite">Ce fichier est requis</span>');
                    } else {
                        fileInfo.removeClass('has-error');
                    }
                }
                
                updateStepIndicators();
            });

            // Validation spéciale pour le type de projet
            $('#appbundle_application_category').on('change', function() {
                const $field = $(this);
                const formGroup = $field.closest('.form-group');
                const value = $field.val();
                
                // Vérifier si une option valide est sélectionnée (pas la première option vide)
                if (!value || value === '' || value === '0' || $field.find('option:selected').text().includes('Sélectionner')) {
                    formGroup.removeClass('is-valid').addClass('has-error');
                    if (formGroup.find('.help-block').length === 0) {
                        formGroup.append('<span class="help-block" role="alert">Veuillez sélectionner un type de projet</span>');
                    }
                    $field.attr('aria-invalid', 'true');
                } else {
                    formGroup.removeClass('has-error').addClass('is-valid');
                    formGroup.find('.help-block').remove();
                    $field.attr('aria-invalid', 'false');
                }
                
                updateStepIndicators();
            });

            // Détecter le bouton cliqué avant la soumission
            let clickedButtonName = null;
            $('input[type="submit"], button[type="submit"]').on('click', function(e) {
                clickedButtonName = $(this).attr('name');
                console.log('=== CLIC BOUTON ===');
                console.log('Bouton cliqué détecté:', clickedButtonName);
                console.log('Bouton element:', $(this));
                console.log('Type du bouton:', $(this).attr('type'));
                console.log('Valeur du bouton:', $(this).val());
                console.log('Classes du bouton:', $(this).attr('class'));
                
                // Si c'est le bouton Enregistrer, permettre la soumission sans validation
                if (clickedButtonName === 'appbundle_application[save]') {
                    console.log('✅ Bouton Enregistrer détecté - validation désactivée');
                    // Marquer que c'est un enregistrement pour éviter la validation
                    $(this).data('is-save', true);
                    console.log('✅ Données marquées sur le bouton');
                    
                    // Forcer la soumission du formulaire
                    console.log('=== FORÇAGE SOUMISSION ===');
                    const form = $(this).closest('form');
                    console.log('Formulaire parent trouvé:', form);
                    console.log('Action du formulaire:', form.attr('action'));
                    console.log('Méthode du formulaire:', form.attr('method'));
                    
                    // Forcer la soumission du formulaire après un court délai
                    setTimeout(function() {
                        console.log('=== SOUMISSION FORCÉE ===');
                        console.log('Tentative de soumission du formulaire...');
                        form[0].submit();
                    }, 100);
                    
                    // Ne pas empêcher la soumission - laisser le formulaire se soumettre
                    console.log('✅ Sortie du gestionnaire de clic - soumission autorisée');
                    return; // Sortir sans empêcher la soumission
                } else {
                    console.log('❌ Autre bouton cliqué:', clickedButtonName);
                }
            });

            // Validation à la soumission
            console.log('=== ATTACHEMENT GESTIONNAIRE FORMULAIRE ===');
            console.log('Nombre de formulaires trouvés:', $('form').length);
            console.log('Formulaire principal:', $('form').first());
            
            $('form').on('submit', function(e) {
                console.log('=== SOUMISSION FORMULAIRE ===');
                console.log('Event:', e);
                console.log('Formulaire:', $(this));
                
                let hasErrors = false;
                let firstErrorSection = null;
                let firstErrorElement = null;

                // Marquer que le formulaire est en cours de soumission
                $('form').data('submitting', true);
                console.log('✅ Formulaire marqué comme en cours de soumission');

                // Utiliser le bouton détecté
                const isSubmitButton = clickedButtonName === 'appbundle_application[submit]';
                const isSaveButton = clickedButtonName === 'appbundle_application[save]';
                
                // Debug: afficher quel bouton a été cliqué
                console.log('=== ANALYSE BOUTON ===');
                console.log('clickedButtonName:', clickedButtonName);
                console.log('isSubmitButton:', isSubmitButton);
                console.log('isSaveButton:', isSaveButton);
                
                // Si c'est le bouton Enregistrer, ne pas valider
                if (isSaveButton) {
                    console.log('✅ Bouton Enregistrer détecté - pas de validation, soumission directe');
                    // Arrêter la vérification périodique pendant la soumission
                    if (spaceCheckInterval) {
                        clearInterval(spaceCheckInterval);
                        console.log('✅ Vérification périodique arrêtée');
                    }
                    // Permettre la soumission sans validation
                    console.log('✅ Autorisation de la soumission du formulaire');
                    return true; // Autoriser la soumission du formulaire
                } else {
                    console.log('❌ Bouton Enregistrer NON détecté, validation activée');
                }
                
                // Fonction pour vérifier et marquer les erreurs
                function checkAndMarkError(element) {
                    const $element = $(element);
                    const value = $element.val();
                    const isRequired = $element.prop('required') || $element.attr('required') === 'required' || $element.closest('.required').length > 0;
                    
                    if (isRequired && (!value || value === '')) {
                        const formGroup = $element.closest('.form-group');
                        formGroup.removeClass('is-valid').addClass('has-error');
                        
                        // Message d'erreur personnalisé pour le type de projet
                        const errorMessage = $element.attr('id') === 'appbundle_application_category' 
                            ? 'Veuillez sélectionner un type de projet'
                            : 'Ce champ est requis';
                            
                        if (formGroup.find('.help-block').length === 0) {
                            formGroup.append(`<span class="help-block" role="alert">${errorMessage}</span>`);
                        }
                        
                        $element.attr('aria-invalid', 'true');
                        
                        // Toujours mettre à jour firstErrorSection
                        firstErrorSection = $element.closest('.section');
                        firstErrorElement = $element;
                        
                        return true;
                    }
                    return false;
                }

                // Valider uniquement si on clique sur le bouton Soumettre (pas sur Enregistrer)
                if (isSubmitButton) {
                    console.log('=== VALIDATION ACTIVÉE ===');
                    console.log('✅ Bouton Soumettre détecté - validation complète');
                    // Vérifier le type de projet en premier
                    const categoryField = $('#appbundle_application_category');
                    const categoryValue = categoryField.val();
                    
                    if (!categoryValue) {
                        hasErrors = true;
                        const formGroup = categoryField.closest('.form-group');
                        formGroup.addClass('has-error');
                        if (formGroup.find('.help-block').length === 0) {
                            formGroup.append('<span class="help-block" role="alert">Veuillez sélectionner un type de projet</span>');
                        }
                        firstErrorSection = categoryField.closest('.section');
                        firstErrorElement = categoryField;
                    }
                    
                    // Si le type de projet est valide, valider les autres champs
                    if (!hasErrors) {
                        // Valider le champ description séparément (requis seulement à la soumission)
                        const descriptionField = $('#appbundle_application_description');
                        const descriptionValue = descriptionField.val();
                        
                        if (!descriptionValue || descriptionValue.trim() === '') {
                            hasErrors = true;
                            const formGroup = descriptionField.closest('.form-group');
                            formGroup.addClass('has-error');
                            if (formGroup.find('.help-block').length === 0) {
                                formGroup.append('<span class="help-block" role="alert">Veuillez décrire votre projet</span>');
                            }
                            if (!firstErrorSection) {
                                firstErrorSection = descriptionField.closest('.section');
                                firstErrorElement = descriptionField;
                            }
                        }
                        
                        $('input[required], select[required], textarea[required]').not('#appbundle_application_category, #appbundle_application_description').each(function() {
                            if (checkAndMarkError(this)) {
                                hasErrors = true;
                                if (!firstErrorSection) {
                                    firstErrorSection = $(this).closest('.section');
                                    firstErrorElement = $(this);
                    }
                }
            });
                        
                        // Valider les fichiers requis (pièce d'identité et Kbis)
                        $('.file-infos').each(function() {
                            const fileInfo = $(this);
                            const fileInput = fileInfo.find('input[type="file"]');
                            
                            // Vérifier si c'est un fichier requis et s'il est vide
                            if (fileInput.length && fileInput.prop('required') && !fileInput[0].files.length) {
                                hasErrors = true;
                                fileInfo.addClass('has-error');
                                
                                // Supprimer les anciens messages d'erreur
                                fileInfo.find('.help-block').remove();
                                
                                // Ajouter le message d'erreur
                                fileInfo.append('<span class="help-block" role="alert" aria-live="polite">Ce fichier est requis</span>');
                                
                                if (!firstErrorSection) {
                                    firstErrorSection = fileInfo.closest('.section');
                                    firstErrorElement = fileInfo;
                                }
                            } else if (fileInput.length && fileInput[0].files.length) {
                                // Si le fichier est présent, supprimer l'erreur
                                fileInfo.removeClass('has-error');
                                fileInfo.find('.help-block').remove();
                            }
                        });
                    }
                } else {
                    console.log('=== VALIDATION DÉSACTIVÉE ===');
                    console.log('❌ Validation désactivée - bouton Enregistrer détecté ou autre');
                    console.log('clickedButtonName final:', clickedButtonName);
                }
                
                    if (hasErrors && isSubmitButton) {
                    console.log('=== ERREURS DÉTECTÉES ===');
                    console.log('❌ Erreurs trouvées, empêchement de la soumission');
                    e.preventDefault();
                    
                    if (firstErrorSection && firstErrorElement) {
                        // Activer l'onglet contenant l'erreur
                        const sectionId = firstErrorSection.attr('id');
                        const tabLink = $(`a[href="#${sectionId}"]`);
                        
                        if (tabLink.length) {
                            // Activer l'onglet
                            $('.section').hide();
                            firstErrorSection.show();
                            $('.indicator').removeClass('active');
                            tabLink.addClass('active');
                            
                                // Scroll vers l'erreur (cible le .form-group pour une marge correcte)
            setTimeout(function() {
                                    const target = firstErrorElement.closest('.form-group');
                                    const offset = (target.length ? target : firstErrorElement).offset().top - 100;
                                $('html, body').animate({
                                    scrollTop: offset
            }, 500);
                                
                                // Focus sur le premier champ en erreur
                                if (firstErrorElement.is(':input')) {
                                    firstErrorElement.focus();
                                }
                            }, 100);
                        }
                    }
                }
            });

            // Initialisation : vérifier les erreurs existantes et mettre à jour les icônes
            $('.has-error').each(function() {
                const section = $(this).closest('.section');
                $(`a[href="#${section.attr('id')}"]`).addClass('has-error');
            });
            
            // Nettoyer tous les styles de validation au chargement
            $('.form-group').removeClass('is-valid has-error');

            // Initialiser les icônes de validation pour les champs déjà remplis
            $('input, select, textarea').each(function() {
                const $field = $(this);
                const value = $field.val();
                const isRequired = $field.prop('required') || $field.attr('required') === 'required' || $field.closest('.required').length > 0;
                
                
                if (isRequired && value && value.trim() !== '') {
                    updateFieldValidationIcon($field);
                }
            });

            // Animation des messages d'erreur
            function animateErrorMessages() {
                $('.help-block[role="alert"]').each(function() {
                    if (!$(this).hasClass('animated')) {
                        $(this).addClass('animated');
                    }
                });
            }

            // Observer les changements dans le DOM pour les nouveaux messages d'erreur
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.addedNodes.length) {
                        animateErrorMessages();
                    }
                });
            });

            observer.observe(document.body, {
                childList: true,
                subtree: true
            });
        });
    </script>
{% endblock %}
