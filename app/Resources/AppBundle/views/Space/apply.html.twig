        }

        #appbundle_application_category::-webkit-scrollbar-thumb:hover {
            background: #999;
        }

        /* Correction du z-index pour la modale d'avertissement */
        #depublished-warning-modal {
            z-index: 9999 !important;
        }
        
        #depublished-warning-modal .modal-dialog {
            z-index: 10000 !important;
        }
        
        #depublished-warning-modal .modal-content {
            z-index: 10001 !important;
